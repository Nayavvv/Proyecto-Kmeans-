{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar kmeans OpenMP con g++-15",
            "type": "shell",
            "command": "/usr/local/bin/g++-15",
            "args": [
                "-O2",
                "-std=c++17",
                "-fopenmp",
                "-isysroot",
                "/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}